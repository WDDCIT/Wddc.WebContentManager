@model Wddc.WebContentManager.Models.WebContent.ClassifiedAds.WebClassifiedAdsModel

@{
    ViewBag.Title = "Classified Ads";
}

@section Styles {
    <link href="https://kendo.cdn.telerik.com/2021.2.511/styles/kendo.default.min.css" rel="stylesheet" />
    <link href="https://kendo.cdn.telerik.com/2021.2.511/styles/kendo.bootstrap-v4.min.css" rel="stylesheet" type="text/css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
}

@section Scripts {

    <script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.11.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>

    <script src="https://kendo.cdn.telerik.com/2021.2.511/js/kendo.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/pagination/pagination.min.js"></script>
    <script src="~/js/pagination/pagination.custom.js"></script>

    <script>

        var clickedActiveAdId = 0, clickedExpiredAdId = 0;
        var startUpdateAd = false;
        var isLogVisible = false;

        function showNotification(type, message) {
            Swal.fire({
                icon: type,
                title: type === 'success' ? 'Success!' : 'Error',
                text: message,
                confirmButtonColor: '#3182ce',
                timer: 3000,
                timerProgressBar: true,
                showConfirmButton: true,
                confirmButtonText: 'OK',
                customClass: { popup: 'swal-above-modal' }
            });
        }

        function toggleLog() {
            isLogVisible = !isLogVisible;
            var container = $('#logContainer');
            var toggleText = $('#logToggleText');

            if (isLogVisible) {
                container.slideDown(300);
                toggleText.text('Hide Activity Log');
                prepareLogList();
            } else {
                container.slideUp(300);
                toggleText.text('Show Activity Log');
            }
        }

        $(document).ready(function () {

            if('@ViewBag.response') {
                if ('@ViewBag.response' == "Success") {
                    showNotification('success', '@ViewBag.Message');
                }
                else {
                    showNotification('error', '@ViewBag.Message');
                }
                if (window.history.replaceState) {
                    window.history.replaceState(null, '', window.location.pathname);
                }
            }

            if (@Model.WebClassifiedAdsActive.Count() > 0) {
                document.getElementById("active").checked = true;
                document.getElementById("active-listings").style.display = 'block';
                document.getElementById("expired-listings").style.display = 'none';

                $.get('@Url.Action("GetFirstActiveAd", "ClassifiedAds")', (data) => {
                     displayActiveAd(data.Ad_ID);
                });
            }
            else {
                if (@Model.WebClassifiedAdsExpired.Count() > 0) {
                    document.getElementById("expired").checked = true;
                    document.getElementById("active-listings").style.display = 'none';
                    document.getElementById("expired-listings").style.display = 'block';

                    $.get('@Url.Action("GetFirstExpiredAd", "ClassifiedAds")', (data) => {
                        displayExpiredAd(data.Ad_ID);
                    });
                }
                else {
                    document.getElementById("active").checked = true;
                    document.getElementById("active-listings").style.display = 'block';
                    document.getElementById("expired-listings").style.display = 'none';

                    emptyTab();
                }
            }

            var newEditor = $("#newLongDescription").kendoEditor({
                stylesheets: [
                    "https://demos.telerik.com/kendo-ui/content/web/editor/editorStyles.css"
                ],
                tools: [
                    "bold",
                    "italic",
                    "underline",
                    "justifyLeft",
                    "justifyCenter",
                    "justifyRight",
                    "insertUnorderedList",
                    "createLink",
                    "unlink",
                    "insertImage",
                    "tableWizard",
                    "createTable",
                    "addRowAbove",
                    "addRowBelow",
                    "addColumnLeft",
                    "addColumnRight",
                    "deleteRow",
                    "deleteColumn",
                    "mergeCellsHorizontally",
                    "mergeCellsVertically",
                    "splitCellHorizontally",
                    "splitCellVertically",
                    "tableAlignLeft",
                    "tableAlignCenter",
                    "tableAlignRight",
                    "formatting",
                    {
                        name: "fontName",
                        items: [
                            { text: "Andale Mono", value: "Andale Mono" },
                            { text: "Arial", value: "Arial" },
                            { text: "Arial Black", value: "Arial Black" },
                            { text: "Book Antiqua", value: "Book Antiqua" },
                            { text: "Comic Sans MS", value: "Comic Sans MS" },
                            { text: "Courier New", value: "Courier New" },
                            { text: "Georgia", value: "Georgia" },
                            { text: "Helvetica", value: "Helvetica" },
                            { text: "Impact", value: "Impact" },
                            { text: "Symbol", value: "Symbol" },
                            { text: "Tahoma", value: "Tahoma" },
                            { text: "Terminal", value: "Terminal" },
                            { text: "Times New Roman", value: "Times New Roman" },
                            { text: "Trebuchet MS", value: "Trebuchet MS" },
                            { text: "Verdana", value: "Verdana" },
                        ]
                    },
                    "fontSize",
                    "foreColor",
                    "backColor",
                ]
            });

            $("#newStartDate").kendoDatePicker({
                format: "MMMM dd, yyyy",
                value: new Date()
            });

            $("#newEndDate").kendoDatePicker({
                format: "MMMM dd, yyyy",
                value: new Date()
            });

            $("#newInfoFileUrl").on("change", function () {
                var fileName = $(this).val().split("\\").pop();
                document.getElementById("newInfoFileUrlText").value = "wddc_members/CS/Classified Ads/" + fileName;
            });

        })


        $('input[type=radio][name=activeOrExpired]').change(function () {

            var activeOrExpired = document.querySelector('input[name="activeOrExpired"]:checked').value;
            var currentCheckedRadio = document.getElementById("active");

            if (activeOrExpired == "active")
                currentCheckedRadio = document.getElementById("expired")

            if (startUpdateAd) {
                Swal.fire({
                    title: 'Would you like to save changes to this form?',
                    showDenyButton: true,
                    showCancelButton: true,
                    confirmButtonText: `Yes`,
                    denyButtonText: `No`,
                }).then((result) => {
                    if (result.isConfirmed) {
                        currentCheckedRadio.checked = true;
                        document.getElementById("save-ad-btn").click();
                    } else if (result.isDenied) {
                        startUpdateAd = false;
                        Swal.fire('Changes are not saved', '', 'info');
                        switchTabs()
                    } else {
                        currentCheckedRadio.checked = true;
                    }
                })
            }
            else {
                switchTabs();
            }
        });

        function switchTabs() {
            $("#active-listings").toggle();
            $("#expired-listings").toggle();

            var activeOrExpired = document.querySelector('input[name="activeOrExpired"]:checked').value;

            if (activeOrExpired == "active") {
                if (@Model.WebClassifiedAdsActive.Count() > 0) {
                    if (clickedActiveAdId == 0) {
                        $.get('@Url.Action("GetFirstActiveAd", "ClassifiedAds")', (data) => {
                            displayActiveAd(data.Ad_ID);
                        });
                    }
                    else {
                        displayActiveAd(clickedActiveAdId);
                    }
                }
                else {
                    emptyTab();
                }
            }
            else {
                if (@Model.WebClassifiedAdsExpired.Count() > 0) {
                    if (clickedExpiredAdId == 0) {
                        $.get('@Url.Action("GetFirstExpiredAd", "ClassifiedAds")', (data) => {
                            displayExpiredAd(data.Ad_ID);
                        });
                    }
                    else {
                        displayExpiredAd(clickedExpiredAdId);
                    }
                }
                else {
                    emptyTab();
                }
            }
        }

        function emptyTab() {
            document.getElementById("details-section").style.display = 'none';
            document.getElementById("ad-id").innerHTML = "  ";
            document.getElementById("delete-ad-btn").disabled = true;
        }

        function liActivate(liElement) {

            var activeLi = liElement.parentElement.querySelector('.active');
            activeLi.classList.remove('active');
            liElement.classList.add('active');
        }

        function liLoad(ad_id) {

            document.getElementById("details-section").style.display = 'block';
            document.getElementById("ad-id").innerHTML = ad_id;
            document.getElementById("new-ad-btn").disabled = false;
            document.getElementById("save-ad-btn").disabled = true;
            document.getElementById("delete-ad-btn").disabled = false;

            $('#details-section').load('@Url.Action("ClassifiedAdsEditorPartial")?adId=' + ad_id, () => {
            });
        }

        function displayActiveAd(ad_id) {

            clickedActiveAdId = ad_id;
            liLoad(ad_id);

        }

        function displayExpiredAd(ad_id) {

            clickedExpiredAdId = ad_id;
            liLoad(ad_id);
        }

        function displayActiveListItem(liElement, ad_id) {

            if (startUpdateAd) {
                Swal.fire({
                    title: 'Would you like to save changes to this form?',
                    showDenyButton: true,
                    showCancelButton: true,
                    confirmButtonText: `Yes`,
                    denyButtonText: `No`,
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById("save-ad-btn").click();
                    } else if (result.isDenied) {
                        startUpdateAd = false;
                        Swal.fire('Changes are not saved', '', 'info');
                        liActivate(liElement);
                        liLoad(ad_id);
                        clickedActiveAdId = ad_id;
                    }
                })
            }
            else {
                liActivate(liElement);
                liLoad(ad_id);
                clickedActiveAdId = ad_id;
            }
        }

        function displayExpiredListItem(liElement, ad_id) {

            if (startUpdateAd) {
                Swal.fire({
                    title: 'Would you like to save changes to this form?',
                    showDenyButton: true,
                    showCancelButton: true,
                    confirmButtonText: `Yes`,
                    denyButtonText: `No`,
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById("save-ad-btn").click();
                    } else if (result.isDenied) {
                        startUpdateAd = false;
                        Swal.fire('Changes are not saved', '', 'info');
                        liActivate(liElement);
                        liLoad(ad_id);
                        clickedExpiredAdId = ad_id;
                    }
                })
            }
            else {
                liActivate(liElement);
                liLoad(ad_id);
                clickedExpiredAdId = ad_id;
            }
        }

        function performBrowse() {
            document.getElementById("newInfoFileUrl").click();
        }

        function validateAddForm() {

            var newLongDesc = document.forms["addNewAdForm"]["newLongDescription"].value;
            if (newLongDesc.trim() == "") {
                showNotification('error', 'Long Description must be filled out');
                return false;
            }

            var newShortDesc = document.forms["addNewAdForm"]["newShortDescription"].value;
            if (newShortDesc.trim() == "") {
                showNotification('error', 'Short Description must be filled out');
                return false;
            }

            var newLocation = document.forms["addNewAdForm"]["newLocation"].value;
            if (newLocation.trim() == "") {
                showNotification('error', 'Location must be filled out');
                return false;
            }

            var newMemberNbr = document.forms["addNewAdForm"]["newMemberNbr"].value;
            if (newMemberNbr.trim() == "") {
                showNotification('error', 'Member # must be filled out');
                return false;
            }

            return true;
        }

        function searchNewMember(ele) {

            var link = '@Url.Action("GetMemberName", "ClassifiedAds")?memberNbr=' + ele.value;
            $.get(link, function (result) {
                document.getElementById("newMemberName").value = result;
            });
        }

        $('#save-ad-btn').click(function (e) {
            var form = document.getElementById("updateAdForm");
            if(validateUpdateForm())
                form.submit();
        });


        $('#delete-ad-btn').click(function (e) {
            var activeOrExpired = document.querySelector('input[name="activeOrExpired"]:checked').value;
            var idToDelete = 0;
            if (activeOrExpired == "active") {
                idToDelete = clickedActiveAdId;
            } else {
                idToDelete = clickedExpiredAdId;
            }

            var deletedMember = document.getElementById("memberNbr").value;

            Swal.fire({
                title: 'Confirm Delete',
                text: 'Delete this classified ad (ID: ' + idToDelete + ', member: ' + deletedMember + ')?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e53e3e',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }).then(function (result) {
                if (result.isConfirmed) {
                    $.post('@Url.Action("DeleteClassifiedAd", "ClassifiedAds")?Id=' + parseInt(idToDelete), (result) => {
                          if (result.success) {
                              showNotification('success', 'Classified ad, member number: ' + deletedMember + ' was deleted successfully!');
                              setTimeout(function() { window.location.href = "@Url.Action("Index", "ClassifiedAds")"; }, 1500);
                          } else {
                              showNotification('error', 'Failure deleting classified ad, member number: ' + deletedMember);
                              prepareLogList();
                          }

                    }).fail((xhr, textStatus, errorThrown) => {
                        showNotification('error', 'Failure deleting classified ad, member number: ' + deletedMember + '. ' + textStatus + ' : ' + errorThrown);
                        prepareLogList();
                    });
                }
            });
        });

        function prepareLogList() {
            setupPagination('log', 'log-list', '@Url.Action("Log", "ClassifiedAds")?referrerUrl=ClassifiedAds', ['Log', 'Username', 'Created'], 7);
        }


    </script>
}

<div class="modern-wrapper">
    <!-- Page Header Banner -->
    <div class="page-header-banner">
        <h2>
            <i class="fa fa-newspaper"></i>
            WDDC Classified Ads
        </h2>
        <p class="subtitle">
            Manage classified ad postings for WDDC member clinics
        </p>
    </div>

    <!-- Main Content -->
    <div class="row">
        <div class="col-lg-5">
            <!-- Ad List Card -->
            <div class="card shadow-sm">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <span class="card-header-title"><i class="fa fa-list"></i> Classified Ads</span>
                    <div class="tab-toggle">
                        <label class="radio-modern">
                            <input type="radio" id="active" name="activeOrExpired" value="active">
                            <span class="radio-label"><i class="fa fa-check-circle"></i> Active</span>
                        </label>
                        <label class="radio-modern">
                            <input type="radio" id="expired" name="activeOrExpired" value="expired">
                            <span class="radio-label"><i class="fa fa-clock"></i> Expired</span>
                        </label>
                    </div>
                </div>
                <div class="card-body p-0">
                    <ul id="active-listings" class="listing-panel" style="display: none;">
                        @foreach (var webClassifiedAd in Model.WebClassifiedAdsActive)
                        {
                            @if (Model.WebClassifiedAdsActive.First() == webClassifiedAd)
                            {
                                <li class="listing-item active" onclick="displayActiveListItem(this, '@webClassifiedAd.Ad_ID')">
                                    <i class="fa fa-file-alt listing-icon"></i>
                                    <span><b>@webClassifiedAd.MemberNbr</b> &nbsp;-&nbsp; @webClassifiedAd.Short_Description</span>
                                </li>
                            }
                            else
                            {
                                <li class="listing-item" onclick="displayActiveListItem(this, '@webClassifiedAd.Ad_ID')">
                                    <i class="fa fa-file-alt listing-icon"></i>
                                    <span><b>@webClassifiedAd.MemberNbr</b> &nbsp;-&nbsp; @webClassifiedAd.Short_Description</span>
                                </li>
                            }
                        }
                    </ul>
                    <ul id="expired-listings" class="listing-panel" style="display: none;">
                        @foreach (var webClassifiedAd in Model.WebClassifiedAdsExpired)
                        {
                            @if (Model.WebClassifiedAdsExpired.First() == webClassifiedAd)
                            {
                                <li class="listing-item active" onclick="displayExpiredListItem(this, '@webClassifiedAd.Ad_ID')">
                                    <i class="fa fa-file-alt listing-icon"></i>
                                    <span><b>@webClassifiedAd.MemberNbr</b> &nbsp;-&nbsp; @webClassifiedAd.Short_Description</span>
                                </li>
                            }
                            else
                            {
                                <li class="listing-item" onclick="displayExpiredListItem(this, '@webClassifiedAd.Ad_ID')">
                                    <i class="fa fa-file-alt listing-icon"></i>
                                    <span><b>@webClassifiedAd.MemberNbr</b> &nbsp;-&nbsp; @webClassifiedAd.Short_Description</span>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <!-- Ad Details Card -->
            <div class="card shadow-sm">
                <div class="card-header d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <button type="button" id="new-ad-btn" class="btn btn-modern btn-primary btn-sm" data-toggle="modal" data-target="#addNewAdModal">
                            <i class="fa fa-plus"></i> New
                        </button>
                        <button type="button" id="save-ad-btn" class="btn btn-modern btn-success btn-sm" disabled>
                            <i class="fa fa-save"></i> Save
                        </button>
                        <button type="button" id="delete-ad-btn" class="btn btn-modern btn-danger btn-sm">
                            <i class="fa fa-trash"></i> Delete
                        </button>
                    </div>
                    <span class="ad-id-badge">Ad ID: <span id="ad-id"></span></span>
                </div>
                <div class="card-body">
                    <div id="details-section"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Activity Log Section -->
    <div class="row mt-3">
        <div class="col-12">
            <div class="log-section">
                <div class="log-header">
                    <button type="button" class="btn-toggle-log" onclick="toggleLog()">
                        <i class="fa fa-history"></i> <span id="logToggleText">Show Activity Log</span>
                    </button>
                </div>
                <div id="logContainer" style="display: none; margin-top: 15px;">
                    <div id="log" class="content-center">
                        <div class="bs-ObjectList-rows" id="log-list"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addNewAdModal" tabindex="-1" role="dialog" aria-labelledby="addNewAdModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content modern-modal">
            <div class="modal-header">
                <span class="modal-title"><i class="fa fa-plus-circle"></i> Add New Classified Ad</span>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form name="addNewAdForm" method="post" action="@Url.Action("AddClassifiedAd", "ClassifiedAds")" enctype="multipart/form-data" onsubmit="return validateAddForm()">
                <div class="modal-body">
                    <div class="row ">
                        <div class="col-12 col-lg-12 col-sm-12 col-xl-12 ">
                            <div class="card" style="  margin: 0 auto">
                                <div id="new-ad-section">
                                    <div class="demo-section k-content wide">
                                        <div class="row form-row">
                                            <div class="col-lg-2 form-label-col">
                                                <label for="newShortDescription" class="control-label control-label-center">Short Description:</label>
                                            </div>
                                            <div class="col-lg-10">
                                                <input id="newShortDescription" name="newShortDescription" class="form-control" type="text">
                                            </div>
                                        </div>
                                        <div class="row form-row">
                                            <div class="col-lg-2 form-label-col">
                                                <label for="newLongDescription" class="control-label control-label-top">Long Description:</label>
                                            </div>
                                            <div class="col-lg-10">
                                                <textarea id="newLongDescription" name="newLongDescription" style="height:250px;" aria-label="newLongDescription"></textarea>
                                            </div>
                                        </div>
                                        <div class="row form-row">
                                            <div class="col-lg-2 form-label-col">
                                                <label for="newLocation" class="control-label control-label-center">Location:</label>
                                            </div>
                                            <div class="col-lg-10">
                                                <input id="newLocation" name="newLocation" class="form-control" type="text" maxlength="100">
                                            </div>
                                        </div>
                                        <div class="row form-row">
                                            <div class="col-lg-2 form-label-col">
                                                <label for="newApplicationInstructions" class="control-label control-label-top">Instructions:</label>
                                            </div>
                                            <div class="col-lg-10">
                                                <textarea class="form-control" id="newApplicationInstructions" name="newApplicationInstructions" maxlength="100"></textarea>
                                            </div>
                                        </div>
                                        <div class="row form-row">
                                            <div class="col-lg-2 form-label-col">
                                                <label class="control-label control-label-top">Contact Info:</label>
                                            </div>
                                            <div class="col-lg-10 contactInfo-col">
                                                <div class="row contactinfo-row">
                                                    <div class="col-lg-2">
                                                        <label class="control-label control-label-top-small" for="newMemberNbr">Member #:</label>
                                                        <input type="text" class="form-control" id="newMemberNbr" name="newMemberNbr" maxlength="5" onchange="searchNewMember(this)">
                                                    </div>
                                                    <div class="col-lg-10">
                                                        <label class="control-label control-label-top-small" for="newMemberName">Member Name:</label>
                                                        <input type="text" class="form-control" id="newMemberName" name="newMemberName" disabled style="color:#888;">
                                                    </div>
                                                </div>
                                                <div class="row contactinfo-row">
                                                    <div class="col-lg-6">
                                                        <label class="control-label control-label-top-small" for="newContactName">Name:</label>
                                                        <input type="text" class="form-control" id="newContactName" name="newContactName" maxlength="50">
                                                    </div>
                                                    <div class="col-lg-6">
                                                        <label class="control-label control-label-top-small" for="newContactTitle">Title:</label>
                                                        <input type="text" class="form-control" id="newContactTitle" name="newContactTitle" maxlength="50">
                                                    </div>
                                                </div>
                                                <div class="row contactinfo-row">
                                                    <div class="col-lg-5">
                                                        <label class="control-label control-label-top-small" for="newContactPhone">Phone:</label>
                                                        <input type="text" class="form-control" id="newContactPhone" name="newContactPhone" maxlength="15">
                                                    </div>
                                                    <div class="col-lg-2">
                                                        <label class="control-label control-label-top-small" for="newContactPhoneExt">Ext:</label>
                                                        <input type="text" class="form-control" id="newContactPhoneExt" name="newContactPhoneExt" maxlength="5">
                                                    </div>
                                                    <div class="col-lg-5">
                                                        <label class="control-label control-label-top-small" for="newContactFax">Fax:</label>
                                                        <input type="text" class="form-control" id="newContactFax" name="newContactFax" maxlength="15">
                                                    </div>
                                                </div>
                                                <div class="row form-row contactinfo-row">
                                                    <div class="col-lg-12">
                                                        <label class="control-label control-label-top-small" for="newContactEmail">Email:</label>
                                                        <input type="email" class="form-control" id="newContactEmail" name="newContactEmail" maxlength="50">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row form-row">
                                            <div class="col-lg-2 form-label-col">
                                                <label for="newInfoFileUrlText" class="control-label control-label-center">Info (File or URL):</label>
                                            </div>
                                            <div class="col-lg-10">
                                                <div class="row" style="display: flex;">
                                                    <div class="col-lg-11">
                                                        <input id="newInfoFileUrlText" name="newInfoFileUrlText" class="form-control" type="text" maxlength="200">
                                                    </div>
                                                    <div class="col-lg-1 control-label-center" style="justify-content: flex-end;">
                                                        <input id="newInfoFileUrl" name="newInfoFileUrl" class="form-control" type="file" style="display:none">
                                                        <button type="button" class="btn btn-light" onclick="performBrowse();" style="margin-right: 0px; padding: 6px 12px;">Browse</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row form-row">
                                            <div class="col-lg-2 form-label-col">
                                                <label for="newStartDate" class="control-label control-label-center">From:</label>
                                            </div>
                                            <div class="col-lg-10">
                                                <input id="newStartDate" name="newStartDate" style="width: 50%" />
                                            </div>
                                        </div>
                                        <div class="row form-row">
                                            <div class="col-lg-2 form-label-col">
