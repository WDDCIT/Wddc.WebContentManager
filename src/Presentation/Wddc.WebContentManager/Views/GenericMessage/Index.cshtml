@{
    ViewBag.Title = "Customers Generic Messages";
}

@section Styles {
    <link href="https://kendo.cdn.telerik.com/2021.2.511/styles/kendo.bootstrap-v4.min.css" rel="stylesheet" type="text/css" />
}

@section Scripts {

    <script src="https://kendo.cdn.telerik.com/2021.2.511/js/kendo.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

        var isLogVisible = false;
        var activityLogGrid;

        function showNotification(type, message) {
            Swal.fire({
                icon: type,
                title: type === 'success' ? 'Success!' : 'Error',
                text: message,
                confirmButtonColor: '#3182ce',
                timer: 3000,
                timerProgressBar: true,
                showConfirmButton: true,
                confirmButtonText: 'OK'
            });
        }

        function toggleLog() {
            isLogVisible = !isLogVisible;
            var container = $('#logContainer');
            var toggleText = $('#logToggleText');
            if (isLogVisible) {
                container.slideDown(300);
                toggleText.text('Hide Activity Log');
                loadActivityLog();
            } else {
                container.slideUp(300);
                toggleText.text('Show Activity Log');
            }
        }

        function loadActivityLog() {
            $.ajax({
                url: '@Url.Action("Log", "GenericMessage")',
                type: 'GET',
                data: { referrerUrl: 'GenericMessage', pageNumber: 1, pageSize: 100 },
                success: function (response) {
                    initActivityLogGrid(response && response.Results ? response.Results : []);
                },
                error: function () { initActivityLogGrid([]); }
            });
        }

        function initActivityLogGrid(logData) {
            if (activityLogGrid) {
                activityLogGrid.destroy();
                $('#gridActivityLog').empty();
            }
            activityLogGrid = $("#gridActivityLog").kendoGrid({
                dataSource: {
                    data: logData,
                    pageSize: 20,
                    schema: {
                        model: {
                            fields: {
                                Text: { type: "string" },
                                User: { type: "string" },
                                Created: { type: "string" }
                            }
                        }
                    }
                },
                height: 400,
                scrollable: true,
                sortable: true,
                pageable: { refresh: true, pageSizes: [10, 20, 50, 100], buttonCount: 5 },
                filterable: { mode: "row" },
                resizable: true,
                columns: [
                    {
                        field: "Text", title: "Log Message", width: "55%",
                        filterable: { cell: { operator: "contains", showOperators: false } },
                        template: function (dataItem) {
                            return '<div style="white-space: pre-wrap; word-wrap: break-word; line-height: 1.5;">' + kendo.htmlEncode(dataItem.Text || '') + '</div>';
                        },
                        attributes: { style: "white-space: normal; word-wrap: break-word;" }
                    },
                    {
                        field: "User", title: "Username", width: "20%",
                        filterable: { cell: { operator: "contains", showOperators: false } },
                        template: function (dataItem) { return dataItem.User || 'Unknown'; }
                    },
                    {
                        field: "Created", title: "Date", width: "25%",
                        filterable: false,
                        template: function (dataItem) { return dataItem.Created || ''; }
                    }
                ]
            }).data("kendoGrid");
        }

        $(document).ready(function () {

            var response = '@TempData["response"]';
            if (response) {
                if (response === 'Success') {
                    showNotification('success', '@Html.Raw(TempData["message"])');
                } else {
                    showNotification('error', '@Html.Raw(TempData["message"])');
                }
            }

            $("#create-form #subject").kendoTextArea({ maxLength: 128, placeholder: "Enter message subject ..." });

            $("#create-form #expiryDate").kendoDatePicker({ dateInput: true, value: new Date(), min: new Date() });

            $("#create-form #site").kendoRadioGroup({
                items: [{ value: -1, label: "All" }, { value: 1, label: "AB" }, { value: 2, label: "MB" }, { value: 3, label: "BC" }],
                layout: "horizontal", value: -1
            });

            $('#create-form #priority').kendoSwitch({ messages: { checked: "High", unchecked: "Low" }, checked: false });

            $("#edit-form #expiryDate").kendoDatePicker({ dateInput: true });

            $("#edit-form #site").kendoRadioGroup({
                items: [{ value: -1, label: "All" }, { value: 1, label: "AB" }, { value: 2, label: "MB" }, { value: 3, label: "BC" }],
                layout: "horizontal"
            });

            $('#edit-form #priority').kendoSwitch({ messages: { checked: "High", unchecked: "Low" } });

            $("#delete-form #expiryDate").kendoDatePicker({ dateInput: true });

            $("#delete-form #site").kendoRadioGroup({
                items: [{ value: -1, label: "All" }, { value: 1, label: "AB" }, { value: 2, label: "MB" }, { value: 3, label: "BC" }],
                layout: "horizontal"
            });

            $('#delete-form #priority').kendoSwitch({ messages: { checked: "High", unchecked: "Low" } });

            var $myGroup = $('#accordion');
            $myGroup.on('show.bs.collapse', '.collapse', function () {
                $myGroup.find('.collapse.in').collapse('hide');
            });

            $("#edit-form #messageId").kendoDropDownList({
                dataSource: { transport: { read: { url: '@Url.Action("GetMessages", "GenericMessage")', dataType: "json" } } },
                dataTextField: "Subject",
                dataValueField: "MsgGenericID",
                filter: "contains",
                optionLabel: "Select a message to update ...",
                open: function () { document.getElementById("message-toUpdate-row").style.visibility = "hidden"; },
                change: function () { searchMessageToUpdate(); }
            });
            $("#edit-form #messageId").data("kendoDropDownList").wrapper.css("font-size", "14px").find("*").css("font-size", "14px");

            $("#delete-form #messageId").kendoDropDownList({
                dataSource: { transport: { read: { url: '@Url.Action("GetMessages", "GenericMessage")', dataType: "json" } } },
                dataTextField: "Subject",
                dataValueField: "MsgGenericID",
                filter: "contains",
                optionLabel: "Select a message to delete ...",
                open: function () { document.getElementById("message-toDelete-row").style.visibility = "hidden"; },
                change: function () { searchMessageToDelete(); }
            });
            $("#delete-form #messageId").data("kendoDropDownList").wrapper.css("font-size", "14px").find("*").css("font-size", "14px");
        });

        function cancelUpdate() {
            $('html, body').animate({ scrollTop: $('#headingOne').offset().top }, 900);
            document.getElementById("message-toUpdate-row").style.visibility = "hidden";
        }

        function cancelDelete() {
            $('html, body').animate({ scrollTop: $('#headingTwo').offset().top }, 900);
            document.getElementById("message-toDelete-row").style.visibility = "hidden";
        }

        function submitCreateForm() {
            $('#create-form-submit').attr('disabled', true);
            $('#create-form #priority').val($('#create-form #priority').data("kendoSwitch").value());
        }

        function submitEditForm() {
            $('#edit-form-submit').attr('disabled', true);
            $('#edit-form #priority').val($('#edit-form #priority').data("kendoSwitch").value());
        }

        function submitDeleteForm() {
            var sw = $('#delete-form #priority').data("kendoSwitch");
            if (sw) $('#delete-form #priority').val(sw.value());
            Swal.fire({
                title: 'Confirm Delete',
                text: 'Are you sure you want to delete this generic message?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#e53e3e',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }).then(function (result) {
                if (result.isConfirmed) {
                    $('#delete-form-submit').attr('disabled', true);
                    document.getElementById('delete-form').submit();
                }
            });
        }

        function searchMessageToUpdate() {
            var messageId = $("#edit-form #messageId").data("kendoDropDownList").value();
            if (!messageId) return;
            document.getElementById("message-toUpdate-row").style.visibility = "hidden";
            $.get('@Url.Action("GetMessageById", "GenericMessage")?Id=' + messageId, function (result) {
                document.getElementById("update-form-textarea-container").innerHTML = "<textarea id='subject' name='subject' style='width: 100%;' required></textarea>";
                $("#edit-form #subject").kendoTextArea({ maxLength: 128, value: result.Subject });
                $("#edit-form #pdf-view-current-filename").html(result.FileName);
                $("#edit-form #pdf-view-current").attr("href", "Message_Generic_Temp\\" + result.FileName);
                $("#edit-form #expiryDate").data("kendoDatePicker").value(result.ExpiryDate);
                $("#edit-form #site").getKendoRadioGroup().value(result.Location == 0 ? -1 : result.Location);
                $("#edit-form #priority").data("kendoSwitch").check(result.Priority == 1);
                document.getElementById("message-toUpdate-row").style.visibility = "visible";
                $('html, body').animate({ scrollTop: $('#headingTwo').offset().top }, 900);
            });
        }

        function searchMessageToDelete() {
            var messageId = $("#delete-form #messageId").data("kendoDropDownList").value();
            if (!messageId) return;
            document.getElementById("message-toDelete-row").style.visibility = "hidden";
            $.get('@Url.Action("GetMessageById", "GenericMessage")?Id=' + messageId, function (result) {
                document.getElementById("delete-form-textarea-container").innerHTML = "<textarea id='subject' name='subject' style='width: 100%;'></textarea>";
                $("#delete-form #subject").kendoTextArea({ maxLength: 128, value: result.Subject, enable: false });
                $("#delete-form #pdf-view-current-filename").html(result.FileName);
                $("#delete-form #pdf-view-current").attr("href", "Message_Generic_Temp\\" + result.FileName);
                $("#delete-form #expiryDate").data("kendoDatePicker").value(result.ExpiryDate);
                $("#delete-form #expiryDate").data("kendoDatePicker").enable(false);
                $("#delete-form #site").getKendoRadioGroup().value(result.Location == 0 ? -1 : result.Location);
                $("#delete-form #site").getKendoRadioGroup().enable(false);
                $("#delete-form #priority").data("kendoSwitch").check(result.Priority == 1);
                $("#delete-form #priority").data("kendoSwitch").enable(false);
                document.getElementById("message-toDelete-row").style.visibility = "visible";
                $('html, body').animate({ scrollTop: $('#headingThree').offset().top }, 900);
            });
        }

    </script>
}

<div class="wrapper wrapper-content animated fadeInRight">

    <!-- Page Header Banner -->
    <div class="row">
        <div class="col-12">
            <div class="page-header-banner">
                <h2>
                    <i class="fa fa-envelope-o"></i>
                    Customers Generic Messages
                </h2>
                <p class="subtitle">Create, edit, and delete generic messages displayed on the website</p>
            </div>
        </div>
    </div>

    <!-- Main Card -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow-sm">
                <div class="card-body gm-card-body">
                    <div class="row">
                        <div class="col-lg-1"></div>
                        <div class="col-lg-10">
                            <div id="accordion">

                                <!-- Create -->
                                <div class="accordion-panel">
                                    <div class="accordion-panel-header" id="headingOne">
                                        <button class="accordion-toggle-btn" data-toggle="collapse" data-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                            <i class="fa fa-plus-circle gm-icon-create"></i> Create Generic Message
                                            <i class="fa fa-chevron-down accordion-chevron"></i>
                                        </button>
                                    </div>
                                    <div id="collapseOne" class="collapse" aria-labelledby="headingOne" data-parent="#accordion">
                                        <div class="accordion-panel-body">
                                            <form id="create-form" name="create-form" method="post" action="@Url.Action("CreateMessage", "GenericMessage")" enctype="multipart/form-data" onsubmit="submitCreateForm();">
                                                <div class="gm-field-row">
                                                    <label class="gm-field-label">Subject</label>
                                                    <div class="gm-field-input"><textarea id="subject" name="subject" style="width: 100%;" required></textarea></div>
                                                </div>
                                                <div class="gm-field-row">
                                                    <label class="gm-field-label">PDF File</label>
                                                    <div class="gm-field-input"><input type="file" class="form-control form-control-sm" id="pdfFile" name="pdfFile" accept="application/pdf" required></div>
                                                </div>
                                                <div class="gm-field-row">
                                                    <label class="gm-field-label">Expiry Date</label>
                                                    <div class="gm-field-input"><input id="expiryDate" name="expiryDate" style="width: 220px;" required /></div>
                                                </div>
                                                <div class="gm-field-row">
                                                    <label class="gm-field-label">Site</label>
                                                    <div class="gm-field-input"><ul id="site" name="site"></ul></div>
                                                </div>
                                                <div class="gm-field-row">
                                                    <label class="gm-field-label">Priority</label>
                                                    <div class="gm-field-input"><input type="checkbox" id="priority" name="priority" aria-label="Priority Switch" /></div>
                                                </div>
                                                <div class="gm-field-row" style="padding-top: 10px;">
                                                    <label class="gm-field-label"></label>
                                                    <div class="gm-field-input">
                                                        <button type="submit" id="create-form-submit" class="btn-gm"><i class="fa fa-plus"></i> Create</button>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Edit -->
                                <div class="accordion-panel">
                                    <div class="accordion-panel-header" id="headingTwo">
                                        <button class="accordion-toggle-btn collapsed" data-toggle="collapse" data-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                                            <i class="fa fa-pencil gm-icon-edit"></i> Edit Generic Message
                                            <i class="fa fa-chevron-down accordion-chevron"></i>
                                        </button>
                                    </div>
                                    <div id="collapseTwo" class="collapse" aria-labelledby="headingTwo" data-parent="#accordion">
                                        <div class="accordion-panel-body">
                                            <form id="edit-form" name="edit-form" method="post" action="@Url.Action("UpdateMessage", "GenericMessage")" enctype="multipart/form-data" onsubmit="submitEditForm();">
                                                <div class="gm-field-row">
                                                    <label class="gm-field-label">Search</label>
                                                    <div class="gm-field-input"><input id="messageId" name="messageId" style="width: 100%;" /></div>
                                                </div>
                                                <div id="message-toUpdate-row" style="visibility: hidden;">
                                                    <div class="gm-divider"></div>
                                                    <div class="gm-field-row">
                                                        <label class="gm-field-label">Subject</label>
                                                        <div class="gm-field-input" id="update-form-textarea-container"></div>
                                                    </div>
                                                    <div class="gm-field-row">
                                                        <label class="gm-field-label">View Current</label>
                                                        <div class="gm-field-input">
                                                            <a href="#" id="pdf-view-current" target="_blank" class="pdf-link">
                                                                <i class="fa fa-file-pdf-o"></i> <span id="pdf-view-current-filename">file</span>
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <div class="gm-field-row">
                                                        <label class="gm-field-label">New PDF File</label>
                                                        <div class="gm-field-input"><input type="file" class="form-control form-control-sm" id="pdfFile" name="pdfFile" accept="application/pdf"></div>
                                                    </div>
                                                    <div class="gm-field-row">
                                                        <label class="gm-field-label">Expiry Date</label>
                                                        <div class="gm-field-input"><input id="expiryDate" name="expiryDate" style="width: 220px;" required /></div>
                                                    </div>
                                                    <div class="gm-field-row">
                                                        <label class="gm-field-label">Site</label>
                                                        <div class="gm-field-input"><ul id="site" name="site"></ul></div>
                                                    </div>
                                                    <div class="gm-field-row">
                                                        <label class="gm-field-label">Priority</label>
                                                        <div class="gm-field-input"><input type="checkbox" id="priority" name="priority" aria-label="Priority Switch" /></div>
                                                    </div>
                                                    <div class="gm-field-row" style="padding-top: 10px;">
                                                        <label class="gm-field-label"></label>
                                                        <div class="gm-field-input">
                                                            <button type="submit" id="edit-form-submit" class="btn-gm"><i class="fa fa-save"></i> Update</button>
                                                            <button type="button" class="btn-gm btn-gm-secondary" onclick="cancelUpdate();"><i class="fa fa-times"></i> Cancel</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Delete -->
                                <div class="accordion-panel">
                                    <div class="accordion-panel-header" id="headingThree">
                                        <button class="accordion-toggle-btn collapsed" data-toggle="collapse" data-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                                            <i class="fa fa-trash gm-icon-delete"></i> Delete Generic Message
                                            <i class="fa fa-chevron-down accordion-chevron"></i>
                                        </button>
                                    </div>
                                    <div id="collapseThree" class="collapse" aria-labelledby="headingThree" data-parent="#accordion">
                                        <div class="accordion-panel-body">
                                            <form id="delete-form" name="delete-form" method="post" action="@Url.Action("DeleteMessage", "GenericMessage")" enctype="multipart/form-data">
                                                <div class="gm-field-row">
                                                    <label class="gm-field-label">Search</label>
                                                    <div class="gm-field-input"><input id="messageId" name="messageId" style="width: 100%;" /></div>
                                                </div>
                                                <div id="message-toDelete-row" style="visibility: hidden;">
                                                    <div class="gm-divider"></div>
                                                    <div class="gm-field-row">
                                                        <label class="gm-field-label">Subject</label>
                                                        <div class="gm-field-input" id="delete-form-textarea-container"></div>
                                                    </div>
                                                    <div class="gm-field-row">
                                                        <label class="gm-field-label">View Current</label>
                                                        <div class="gm-field-input">
                                                            <a href="#" id="pdf-view-current" target="_blank" class="pdf-link">
                                                                <i class="fa fa-file-pdf-o"></i> <span id="pdf-view-current-filename">file</span>
                                                            </a>
                                                        </div>
                                                    </div>
                                                    <div class="gm-field-row">
                                                        <label class="gm-field-label">Expiry Date</label>
                                                        <div class="gm-field-input"><input id="expiryDate" name="expiryDate" style="width: 220px;" /></div>
                                                    </div>
                                                    <div class="gm-field-row">
                                                        <label class="gm-field-label">Site</label>
                                                        <div class="gm-field-input"><ul id="site" name="site"></ul></div>
                                                    </div>
                                                    <div class="gm-field-row">
                                                        <label class="gm-field-label">Priority</label>
                                                        <div class="gm-field-input"><input type="checkbox" id="priority" name="priority" aria-label="Priority Switch" /></div>
                                                    </div>
                                                    <div class="gm-field-row" style="padding-top: 10px;">
                                                        <label class="gm-field-label"></label>
                                                        <div class="gm-field-input">
                                                            <button type="button" id="delete-form-submit" class="btn-gm btn-gm-danger" onclick="submitDeleteForm()"><i class="fa fa-trash"></i> Delete</button>
                                                            <button type="button" class="btn-gm btn-gm-secondary" onclick="cancelDelete();"><i class="fa fa-times"></i> Cancel</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                        <div class="col-lg-1"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Log Section -->
    <div class="row">
        <div class="col-12">
            <div class="log-section">
                <div class="log-header">
                    <button type="button" class="btn-toggle-log" onclick="toggleLog()">
                        <i class="fa fa-history"></i> <span id="logToggleText">Show Activity Log</span>
                    </button>
                </div>
                <div id="logContainer" style="display: none; margin-top: 15px;">
                    <div id="gridActivityLog"></div>
                </div>
            </div>
        </div>
    </div>

</div>

<style>

    #page-heading, .breadcrumb { display: none; }

    .wrapper-content { padding: 15px 20px 30px; }

    /* ===== Page Header Banner ===== */
    .page-header-banner {
        background: linear-gradient(135deg, #3182ce 0%, #2c5282 100%);
        color: white;
        padding: 12px 20px;
        margin-bottom: 20px;
        border-radius: 6px;
        box-shadow: 0 2px 10px rgba(49, 130, 206, 0.3);
    }

        .page-header-banner h2 {
            margin: 0 0 2px 0;
            font-size: 20px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
            color: white;
        }

        .page-header-banner h2 i { font-size: 20px; opacity: 0.9; }

        .page-header-banner .subtitle {
            margin: 0;
            font-size: 13px;
            opacity: 0.85;
            font-weight: 400;
        }

    /* ===== Card ===== */
    .card.shadow-sm {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.08) !important;
        margin-bottom: 20px;
    }

    .gm-card-body { padding: 28px 30px; }

    /* ===== Accordion ===== */
    .accordion-panel {
        border: none;
        border-radius: 8px;
        margin-bottom: 12px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,0.07);
        background: white;
    }

    .accordion-panel-header {
        background: linear-gradient(to bottom, #f8f9fa 0%, #edf2f7 100%);
        border-bottom: 1px solid #e2e8f0;
    }

    .accordion-toggle-btn {
        display: flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        padding: 15px 20px;
        background: none;
        border: none;
        text-align: left;
        font-size: 15px;
        font-weight: 600;
        color: #2d3748;
        cursor: pointer;
        transition: all 0.2s;
        letter-spacing: 0.2px;
    }

        .accordion-toggle-btn:hover { background: rgba(49, 130, 206, 0.06); }
        .accordion-toggle-btn:not(.collapsed) { color: #3182ce; background: linear-gradient(to bottom, #ebf4ff, #dbeafe); }

    .gm-icon-create { color: #38a169; font-size: 16px; }
    .gm-icon-edit   { color: #3182ce; font-size: 16px; }
    .gm-icon-delete { color: #e53e3e; font-size: 16px; }

    .accordion-chevron { margin-left: auto; transition: transform 0.25s; font-size: 12px; color: #a0aec0; }
    .accordion-toggle-btn:not(.collapsed) .accordion-chevron { transform: rotate(180deg); color: #3182ce; }

    .accordion-panel-body {
        padding: 28px 24px;
        border-top: 1px solid #e2e8f0;
        background: white;
    }

    /* ===== Form Fields ===== */
    .gm-field-row {
        display: flex;
        align-items: flex-start;
        margin-bottom: 18px;
        gap: 16px;
    }

    .gm-field-label {
        min-width: 130px;
        font-size: 13px;
        font-weight: 600;
        color: #495057;
        padding-top: 8px;
        text-align: right;
        flex-shrink: 0;
    }

    .gm-field-input { flex: 1; }

    .gm-field-input .form-control-sm {
        border-radius: 4px;
        border: 1px solid #cbd5e0;
        padding: 6px 10px;
    }

    .gm-divider { border-top: 2px dashed #e2e8f0; margin: 24px 0; }

    /* ===== Message search dropdown ===== */
    #edit-form .k-dropdownlist,
    #edit-form .k-dropdownlist *,
    #delete-form .k-dropdownlist,
    #delete-form .k-dropdownlist * {
        font-size: 14px !important;
    }

    /* ===== Buttons ===== */
    .btn-gm {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 20px;
        background: linear-gradient(135deg, #3182ce 0%, #2c5282 100%);
        color: white;
        border: none;
        border-radius: 5px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        margin-right: 8px;
        transition: all 0.2s;
        box-shadow: 0 2px 4px rgba(49, 130, 206, 0.3);
    }

        .btn-gm:hover { opacity: 0.88; color: white; transform: translateY(-1px); box-shadow: 0 4px 8px rgba(49, 130, 206, 0.35); }
