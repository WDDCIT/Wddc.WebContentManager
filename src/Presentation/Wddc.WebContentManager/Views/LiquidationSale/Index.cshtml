@model Wddc.WebContentManager.Models.WebContent.Sales.LiquidationSale.LiquidationSaleModel

@{
    ViewBag.Title = "Liquidation Sale (Returns)";
}

@section Styles {
    <link href="https://kendo.cdn.telerik.com/2021.2.511/styles/kendo.bootstrap-v4.min.css" rel="stylesheet" type="text/css" />
}

@section Scripts {

    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.18.1/moment.min.js"></script>
    <script src="https://ajax.aspnetcdn.com/ajax/jquery.validate/1.11.0/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>

    <script src="https://kendo.cdn.telerik.com/2021.2.511/js/kendo.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/2.4.0/jszip.js"></script>

    <script src="~/js/pagination/pagination.min.js"></script>
    <script src="~/js/pagination/pagination.custom.js"></script>

    <script>

        var liquidationSaleDataSource, salesGrid;
        var isLogVisible = false;
        var activityLogGrid;
        var today = new Date(), addressResult;
        var dd = String(today.getDate()).padStart(2, '0');
        var mm = String(today.getMonth() + 1).padStart(2, '0');
        var yyyy = today.getFullYear();
        today = mm + '/' + dd + '/' + yyyy;

        function showNotification(type, message) {
            Swal.fire({
                icon: type,
                title: type === 'success' ? 'Success!' : 'Error',
                text: message,
                confirmButtonColor: '#3182ce',
                timer: 3000,
                timerProgressBar: true,
                showConfirmButton: true,
                confirmButtonText: 'OK'
            });
        }

        function toggleLog() {
            isLogVisible = !isLogVisible;
            var container = $('#logContainer');
            var toggleText = $('#logToggleText');

            if (isLogVisible) {
                container.slideDown(300);
                toggleText.text('Hide Activity Log');
                loadActivityLog();
            } else {
                container.slideUp(300);
                toggleText.text('Show Activity Log');
            }
        }

        function loadActivityLog() {
            $.ajax({
                url: '@Url.Action("Log", "LiquidationSale")',
                type: 'GET',
                data: {
                    referrerUrl: 'LiquidationSale',
                    pageNumber: 1,
                    pageSize: 100
                },
                success: function (response) {
                    if (response && response.Results) {
                        initActivityLogGrid(response.Results);
                    } else {
                        initActivityLogGrid([]);
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Error loading activity log:', error);
                    showNotification('error', 'Failed to load activity log: ' + error);
                    initActivityLogGrid([]);
                }
            });
        }

        function initActivityLogGrid(logData) {
            if (activityLogGrid) {
                activityLogGrid.destroy();
                $('#gridActivityLog').empty();
            }

            activityLogGrid = $("#gridActivityLog").kendoGrid({
                dataSource: {
                    data: logData,
                    pageSize: 20,
                    schema: {
                        model: {
                            fields: {
                                Text: { type: "string" },
                                User: { type: "string" },
                                Created: { type: "string" }
                            }
                        }
                    }
                },
                height: 400,
                scrollable: true,
                sortable: true,
                pageable: {
                    refresh: true,
                    pageSizes: [10, 20, 50, 100],
                    buttonCount: 5
                },
                filterable: {
                    mode: "row"
                },
                resizable: true,
                columns: [
                    {
                        field: "Text",
                        title: "Log Message",
                        width: "55%",
                        filterable: {
                            cell: {
                                operator: "contains",
                                showOperators: false
                            }
                        },
                        template: function (dataItem) {
                            var text = dataItem.Text || '';
                            return '<div style="white-space: pre-wrap; word-wrap: break-word; line-height: 1.5;">' +
                                kendo.htmlEncode(text) + '</div>';
                        },
                        attributes: { style: "white-space: normal; word-wrap: break-word;" }
                    },
                    {
                        field: "User",
                        title: "Username",
                        width: "20%",
                        filterable: {
                            cell: {
                                operator: "contains",
                                showOperators: false
                            }
                        },
                        template: function (dataItem) {
                            return dataItem.User || 'Unknown';
                        }
                    },
                    {
                        field: "Created",
                        title: "Date",
                        width: "25%",
                        filterable: false,
                        template: function (dataItem) {
                            return dataItem.Created || '';
                        }
                    }
                ]
            }).data("kendoGrid");
        }

        $(document).ready(function () {

            // Handle ViewBag alerts via SweetAlert2 toast
            var response = '@ViewBag.response';
            var message = '@ViewBag.Message';
            if (response === 'Success') {
                showNotification('success', message || 'Operation completed successfully');
            } else if (response && response !== '') {
                showNotification('error', message || 'An error occurred');
            }

            var link = '@Url.Action("GetWebLiquidation", "LiquidationSale")';
            liquidationSaleDataSource = new kendo.data.DataSource({
                transport: {
                    read: {
                        url: '@Url.Action("GetWebLiquidation", "LiquidationSale")',
                        dataType: "json"
                    },
                    update: {
                        url: '@Url.Action("UpdateWebLiquidation", "LiquidationSale")',
                        dataType: "json"
                    },
                    create: {
                        url: '@Url.Action("CreateWebLiquidation", "LiquidationSale")',
                        type: "POST",
                        dataType: "json"
                    },
                    destroy: {
                        url: '@Url.Action("DeleteWebLiquidation", "LiquidationSale")',
                        type: "POST",
                        dataType: "json"
                    },
                    parameterMap: function (options, operation) {
                        if (operation === "update" || operation === "create" || operation === "destroy") {
                            if (operation === "create") {
                                options.Description = document.getElementById("Description").value;
                                options.Regular_Cost = document.getElementById("Regular_Cost").value;
                            }
                            var d = new Date(options.Expiry_Date);
                            options.Expiry_Date = kendo.toString(new Date(d), "yyyy-MM-ddTHH:mm:ss");
                            return options;
                        }

                    }
                },
                requestEnd: function (e) {
                    if (e.type === "create") {
                        showNotification('success', 'Item added successfully');
                    } else if (e.type === "update") {
                        showNotification('success', 'Item updated successfully');
                    } else if (e.type === "destroy") {
                        showNotification('success', 'Item deleted successfully');
                    }
                },
                error: function (e) {
                    var message = 'An error occurred';
                    if (e.xhr && e.xhr.responseJSON && e.xhr.responseJSON.message) {
                        message = e.xhr.responseJSON.message;
                    }
                    showNotification('error', message);
                    this.cancelChanges();
                },
                schema: {
                    model: {
                        id: "ID",
                        fields: {
                            ID: { editable: false, type: "number" },
                            RET_Code: { editable: true, type: "string", validation: { required: true } },
                            REG_Code: { type: "string", validation: { required: true } },
                            Description: { editable: true, type: "string" },
                            Reason: { editable: true, type: "string"},
                            Source: { editable: true, type: "string" },
                            QOH: { editable: true, type: "number", validation: { required: true, min: 0 } },
                            Expiry_Date: { editable: true, type: "date" },
                            Regular_Cost: { editable: true, type: "number", validation: { required: true, min: 0 } },
                            Liquidation_Cost: { editable: true, type: "number", validation: { required: true, min: 0 } }
                        }
                    }
                }
            });

            salesGrid = $("#salesGrid").kendoGrid({
                dataSource: liquidationSaleDataSource,
                toolbar: ["Refresh", "excel", "create", "Delete Selected"],
                excel: {
                    fileName: "Liquidation Sales (Returns)_" + today + ".xlsx",
                    proxyURL: "https://demos.telerik.com/kendo-ui/service/export",
                    allPages: true
                },
                sortable: {
                    mode: "multiple",
                    allowUnsort: true,
                    showIndexes: true
                },
                filterable: true,
                resizable: true,
                edit: function (e) {
                    // Style the popup window
                    var editWindow = e.container.data("kendoWindow");
                    editWindow.setOptions({ width: 700 });
                    editWindow.center();

                    // Style form fields inside popup
                    e.container.find(".k-edit-label label").css({
                        "font-weight": "600",
                        "color": "#495057",
                        "font-size": "13px"
                    });
                    e.container.find(".k-edit-field .k-textbox, .k-edit-field .k-numerictextbox, .k-edit-field .k-datepicker").css({
                        "width": "100%"
                    });

                    // Replace Source input with a resizable textarea
                    // Replace Source input with a resizable textarea
                    var sourceInput = e.container.find('[name="Source"]');
                    if (sourceInput.length) {
                        var textarea = $('<textarea class="k-textbox source-textarea" name="Source" rows="5" placeholder="Enter notes or source details..."></textarea>');
                        textarea.val(sourceInput.val());
                        sourceInput.replaceWith(textarea);

                        // Bind textarea changes back to the Kendo model
                        textarea.on('input', function () {
                            e.model.set("Source", $(this).val());
                        });
                    }

                    if (e.model.isNew()) {
                        var addButtons = document.getElementsByClassName("k-grid-update");
                        addButtons[0].innerHTML = '<span class="k-icon k-i-check"></span>Add';
                        var windowTitles = document.getElementsByClassName("k-window-title");
                        windowTitles[0].innerHTML = "Add New Item";
                        document.getElementById("REG_Code").onchange = function () { getItemInfo() };
                    }
                },
                editable: {
                    mode: "popup",
                    confirmation: false
                },
                columns: [
                    { selectable: true, width: "40px" },
                    {
                        field: "RET_Code",
                        title: "Location",
                        filterable: {
                            multi: true,
                            search: true
                        },
                        attributes: { class: "grid-cell", style: "text-align: center;" }
                    },
                    {
                        field: "REG_Code",
                        title: "Item Number",
                        filterable: {
                            multi: true,
                            search: true
                        },
                        editable: isEditable,
                        attributes: { class: "grid-cell", style: "text-align: center;" }
                    },
                    {
                        field: "Description",
                        title: "Description",
                        filterable: false,
                        attributes: { class: "grid-cell" }
                    },
                    {
                        field: "Reason",
                        title: "Reason",
                        filterable: {
                            multi: true,
                            search: true
                        },
                        attributes: { class: "grid-cell" }
                    },
                    {
                        field: "Source",
                        title: "Source",
                        filterable: {
                            multi: true,
                            search: true
                        },
                        template: function (dataItem) {
                            var val = dataItem.Source || "";
                            return '<span class="source-cell" title="' + kendo.htmlEncode(val) + '">' + kendo.htmlEncode(val) + '</span>';
                        },
                        attributes: { class: "grid-cell" }
                    },
                    {
                        field: "Expiry_Date",
                        title: "Expiry",
                        width: "90px",
                        filterable: false,
                        template: function (dataItem) {
                            if (dataItem.Expiry_Date == null)
                                return "";
                            return moment(dataItem.Expiry_Date).format('MM/YYYY');
                        },
                        attributes: { class: "grid-cell", style: "text-align: center;" }
                    },
                    {
                        field: "QOH",
                        title: "QOH",
                        filterable: {
                            multi: true,
                            search: true
                        },
                        attributes: { class: "grid-cell", style: "text-align: center;" }
                    },
                    {
                        field: "Regular_Cost",
                        title: "Reg Price",
                        filterable: {
                            multi: true,
                            search: true
                        },
                        format: "{0:c2}",
                        step: 0.1,
                        attributes: { class: "grid-cell", style: "text-align: center;" }
                    },
                    {
                        field: "Liquidation_Cost",
                        title: "Sale Price",
                        filterable: {
                            multi: true,
                            search: true
                        },
                        format: "{0:c2}",
                        step: 0.1,
                        attributes: { class: "grid-cell", style: "text-align: center;" }
                    },
                    {
                        command: [
                            { name: "edit", className: "btn-row-edit" },
                            { name: "customDelete", text: "Delete", click: confirmRowDelete, className: "btn-row-delete" }
                        ],
                        title: "&nbsp;",
                        width: "200px"
                    }
                ]
            }).data("kendoGrid");

            salesGrid.bind("dataBound", grid_dataBound);
            salesGrid.bind("save", grid_save);

            salesGrid.autoFitColumn("QOH");
            salesGrid.autoFitColumn("Regular_Cost");
            salesGrid.autoFitColumn("Liquidation_Cost");
            salesGrid.autoFitColumn("RET_Code");
            salesGrid.autoFitColumn("REG_Code");

            var refreshBtn = document.getElementsByClassName('k-grid-Refresh')[0];
            refreshBtn.innerHTML = "<span class='k-icon k-i-reload'></span> Refresh";

            $("#salesGrid").find(".k-grid-toolbar").on("click", ".k-grid-Refresh", function (e) {
                e.preventDefault();
                salesGrid.dataSource.read();
                if (isLogVisible) loadActivityLog();
            });

           $("#salesGrid").find(".k-grid-toolbar").on("click", ".k-grid-DeleteSelected", function (e) {
                var checkedRows = $("#salesGrid").find("input:checked");
                if (checkedRows.length === 0) {
                    Swal.fire({
                        icon: 'info',
                        title: 'No Selection',
                        text: 'Please select at least one item to delete.',
                        confirmButtonColor: '#3182ce'
                    });
                    return;
                }

                Swal.fire({
                    title: 'Confirm Bulk Delete',
                    text: 'Delete ' + checkedRows.length + ' selected item(s)?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#e53e3e',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete all!',
                    cancelButtonText: 'Cancel'
                }).then(function (result) {
                    if (result.isConfirmed) {
                        // Collect all data items while DOM is still intact
                        var itemsToDelete = [];
                        checkedRows.each(function () {
                            var row = $(this).closest('tr');
                            var dataItem = salesGrid.dataItem(row);
                            if (dataItem) {
                                itemsToDelete.push(dataItem);
                            }
                        });

                        // Remove from DataSource without triggering individual syncs
                        itemsToDelete.forEach(function (item) {
                            salesGrid.dataSource.remove(item);
                        });

                        // Single sync sends all delete requests
                        salesGrid.dataSource.sync();
                        if (isLogVisible) loadActivityLog();
                    }
                });
            });

            function isEditable(e) {
                return e.ID == 0;
            }

            function getItemInfo() {
                $.getJSON('@Url.Action("GetItemInfo", "LiquidationSale")?itemNumber=' + document.getElementById("REG_Code").value, function (json) {
                    document.getElementById("Regular_Cost").value = json.price;
                    document.getElementById("Description").value = json.description;
                    var node1 = document.querySelectorAll('[title="Reg Price"]')[0];
                    var node2 = document.querySelectorAll('[title="Reg Price"]')[1];
                    node1.value = json.price;
                    node2.value = json.price;
                });
            }

            function grid_dataBound(e) {
                document.getElementById("salesGridTotal").innerHTML =
                    '<i class="fa fa-database"></i> <strong>' + liquidationSaleDataSource.total() + '</strong> of ' + liquidationSaleDataSource.data().length + ' items';
            }

            function grid_save(e) {
                e.sender.one("dataBound", function () {
                    e.sender.dataSource.read();
                    if (isLogVisible) loadActivityLog();
                });
            }

            function confirmRowDelete(e) {
                e.preventDefault();
                var grid = $("#salesGrid").data("kendoGrid");
                var tr = $(e.currentTarget).closest("tr");
                var dataItem = grid.dataItem(tr);
                var itemId = dataItem.ID;

                Swal.fire({
                    title: 'Confirm Delete',
                    text: 'Delete item ' + (dataItem.REG_Code || '') + ' at location ' + (dataItem.RET_Code || '') + '?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#e53e3e',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Yes, delete it!',
                    cancelButtonText: 'Cancel'
                }).then(function (result) {
                    if (result.isConfirmed) {
                        // Re-fetch by ID — the TR may be stale after async confirmation
                        var currentItem = grid.dataSource.get(itemId);
                        if (currentItem) {
                            grid.dataSource.remove(currentItem);
                            grid.dataSource.sync();
                        }
                        if (isLogVisible) loadActivityLog();
                    }
                });
            }

        })

    </script>
}

