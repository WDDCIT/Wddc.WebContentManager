    <!-- Page Header -->
    <div class="row">
        <div class="col-12">
            <div class="page-header-banner">
                <h2>
                    <i class="fa fa-tags"></i>
                    Liquidation Sale — Returns
                </h2>
                <p class="subtitle">
                    Manage liquidation inventory, pricing, and return items across locations
                </p>
            </div>
        </div>
    </div>

    <!-- Main Grid Card -->
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow-sm">
